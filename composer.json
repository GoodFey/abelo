{
  "name": "abelo/website",
  "description": "Веб-сайт на PHP (Laravel подобный)",
  "type": "project",
  "require": {
    "php": ">=8.4",
    "smarty/smarty": "^4.4",
    "vlucas/phpdotenv": "^5.6",
    "ext-pdo": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "files": [
      "app/Helpers/helpers.php"
    ],
    "psr-4": {
      "App\\": "app/",
      "Config\\": "config/",
      "Database\\": "database/",
      "Tests\\": "tests/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "start": "php -S localhost:8000 -t public"
  }
}
