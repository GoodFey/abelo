{
  "name": "abelo/website",
  "description": "Веб-сайт на PHP (Laravel подобный)",
  "type": "project",
  "require": {
    "php": ">=8.1",
    "smarty/smarty": "^4.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Config\\": "config/",
      "Database\\": "database/",
      "Tests\\": "tests/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "start": "php -S localhost:8000 -t public"
  }
}
